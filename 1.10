#include <iostream>
using namespace std;
int main() {
    int n=6;
    for (int i = 0; i < n; i++) {
        if (i == 0 || i == n - 1) {
            for (int j = 0; j < 5; j++) {
                cout << "*";}
        }
        else if (i == 1 || i == n - 2) {
            cout << " ";
            for (int j = 0; j < 3; j++) {
                cout << "*";}
        }
        else {cout << "  *";}
        cout << endl;}
    return 0;
}
